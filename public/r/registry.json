{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "therapy-ui",
  "homepage": "https://github.com/geraldbahati/therapy-ui",
  "items": [
    {
      "name": "therapy-ui",
      "type": "registry:item",
      "title": "Therapy UI",
      "description": "Install the Therapy UI theme, utilities, and component set.",
      "registryDependencies": [
        "geraldbahati/therapy-ui/theme",
        "geraldbahati/therapy-ui/button",
        "geraldbahati/therapy-ui/autocomplete-field",
        "geraldbahati/therapy-ui/chip-list",
        "geraldbahati/therapy-ui/filter-controls",
        "geraldbahati/therapy-ui/search-field"
      ]
    },
    {
      "name": "theme",
      "type": "registry:theme",
      "title": "Therapy Theme",
      "description": "Therapy brand color tokens and CSS utilities.",
      "cssVars": {
        "theme": {
          "breakpoint-nav": "72.5rem",
          "font-heading": "var(--font-sans)",
          "color-ring": "var(--ring)",
          "color-input": "var(--input)",
          "color-border": "var(--border)",
          "color-destructive": "var(--destructive)",
          "color-accent-foreground": "var(--accent-foreground)",
          "color-accent": "var(--accent)",
          "color-muted-foreground": "var(--muted-foreground)",
          "color-muted": "var(--muted)",
          "color-secondary-foreground": "var(--secondary-foreground)",
          "color-secondary": "var(--secondary)",
          "color-primary-foreground": "var(--primary-foreground)",
          "color-primary": "var(--primary)",
          "color-brand": "var(--brand)",
          "color-brand-foreground": "var(--brand-foreground)",
          "color-scribble": "var(--scribble)",
          "color-popover-foreground": "var(--popover-foreground)",
          "color-popover": "var(--popover)",
          "color-card-foreground": "var(--card-foreground)",
          "color-card": "var(--card)",
          "color-foreground": "var(--foreground)",
          "color-background": "var(--background)",
          "radius-sm": "calc(var(--radius) * 0.6)",
          "radius-md": "calc(var(--radius) * 0.8)",
          "radius-lg": "var(--radius)",
          "radius-xl": "calc(var(--radius) * 1.4)",
          "radius-2xl": "calc(var(--radius) * 1.8)",
          "radius-3xl": "calc(var(--radius) * 2.2)",
          "radius-4xl": "calc(var(--radius) * 2.6)",
          "font-sans": "var(--font-sans)"
        },
        "light": {
          "background": "oklch(0.931 0.015 88.5)",
          "foreground": "oklch(0.285 0 0)",
          "rule-color": "var(--primary)",
          "card": "oklch(1 0 0)",
          "card-foreground": "oklch(0.145 0 0)",
          "popover": "oklch(1 0 0)",
          "popover-foreground": "oklch(0.145 0 0)",
          "primary": "oklch(0.617 0.184 258.9)",
          "primary-foreground": "oklch(0.985 0.005 258.9)",
          "brand": "oklch(0.665 0.2 38)",
          "brand-foreground": "oklch(0.985 0.01 38)",
          "scribble": "oklch(0.82 0.066 308)",
          "secondary": "oklch(0.722 0.174 156.4)",
          "secondary-foreground": "oklch(0.985 0.01 156.4)",
          "muted": "oklch(0.97 0 0)",
          "muted-foreground": "oklch(0.556 0 0)",
          "accent": "oklch(0.97 0 0)",
          "accent-foreground": "oklch(0.205 0 0)",
          "destructive": "oklch(0.577 0.245 27.325)",
          "border": "oklch(0.922 0 0)",
          "input": "oklch(0.922 0 0)",
          "ring": "oklch(0.617 0.184 258.9)",
          "radius": "0.625rem"
        },
        "dark": {
          "background": "oklch(0.145 0 0)",
          "foreground": "oklch(0.985 0 0)",
          "rule-color": "color-mix(in oklab, var(--primary) 40%, transparent)",
          "card": "oklch(0.205 0 0)",
          "card-foreground": "oklch(0.985 0 0)",
          "popover": "oklch(0.205 0 0)",
          "popover-foreground": "oklch(0.985 0 0)",
          "primary": "oklch(0.655 0.18 258.9)",
          "primary-foreground": "oklch(0.205 0.03 258.9)",
          "brand": "oklch(0.665 0.2 38)",
          "brand-foreground": "oklch(0.985 0.01 38)",
          "secondary": "oklch(0.72 0.17 156.4)",
          "secondary-foreground": "oklch(0.205 0.03 156.4)",
          "muted": "oklch(0.269 0 0)",
          "muted-foreground": "oklch(0.708 0 0)",
          "accent": "oklch(0.269 0 0)",
          "accent-foreground": "oklch(0.985 0 0)",
          "destructive": "oklch(0.704 0.191 22.216)",
          "border": "oklch(1 0 0 / 10%)",
          "input": "oklch(1 0 0 / 15%)",
          "ring": "oklch(0.655 0.18 258.9)"
        }
      },
      "css": {
        ".dashed-rule-x": {
          "background-image": "repeating-linear-gradient(to right, var(--rule-color) 0 6px, transparent 6px 12px)",
          "background-size": "100% 1px",
          "background-position": "0 100%",
          "background-repeat": "no-repeat"
        },
        ".stamp-edge-top": {
          "--stamp-hole": "15px",
          "--stamp-gap": "55px",
          "-webkit-mask": "radial-gradient(var(--stamp-hole) at center top, #0000 98%, #000) 0 0 / var(--stamp-gap) 100%",
          "-webkit-mask-repeat": "repeat-x",
          "mask": "radial-gradient(var(--stamp-hole) at center top, #0000 98%, #000) 0 0 / var(--stamp-gap) 100%",
          "mask-repeat": "repeat-x"
        },
        ".stamp-edge-top-border": {
          "--stamp-hole": "15px",
          "--stamp-gap": "55px",
          "--stamp-ring": "2px",
          "-webkit-mask": "radial-gradient(var(--stamp-hole) at center top, #0000 100%, #000) 0 0 / var(--stamp-gap) 100%",
          "-webkit-mask-repeat": "repeat-x",
          "mask": "radial-gradient(var(--stamp-hole) at center top, #0000 100%, #000) 0 0 / var(--stamp-gap) 100%",
          "mask-repeat": "repeat-x",
          "background-image": "radial-gradient(circle at 50% 0%, transparent var(--stamp-hole), currentColor var(--stamp-hole), currentColor calc(var(--stamp-hole) + var(--stamp-ring)), transparent calc(var(--stamp-hole) + var(--stamp-ring))), linear-gradient(to bottom, currentColor var(--stamp-ring), transparent var(--stamp-ring))",
          "background-size": "var(--stamp-gap) 100%, 100% 100%",
          "background-position": "0 0, 0 0",
          "background-repeat": "repeat-x, no-repeat"
        }
      }
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utilities",
      "description": "Class name merge utility.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "registry/lib/utils.ts",
          "type": "registry:lib",
          "target": "@lib/utils.ts"
        }
      ]
    },
    {
      "name": "button-variants",
      "type": "registry:lib",
      "title": "Button Variants",
      "description": "Class variance configuration for Therapy buttons.",
      "dependencies": ["class-variance-authority"],
      "files": [
        {
          "path": "registry/lib/button-variants.ts",
          "type": "registry:lib",
          "target": "@lib/button-variants.ts"
        }
      ]
    },
    {
      "name": "icons",
      "type": "registry:ui",
      "title": "Icons",
      "description": "Small outline icons used by Therapy UI components.",
      "files": [
        {
          "path": "registry/ui/icons.tsx",
          "type": "registry:ui",
          "target": "@ui/icons.tsx"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Therapy button primitive with brand variants.",
      "dependencies": ["@base-ui/react"],
      "registryDependencies": [
        "geraldbahati/therapy-ui/theme",
        "geraldbahati/therapy-ui/utils",
        "geraldbahati/therapy-ui/button-variants"
      ],
      "files": [
        {
          "path": "registry/ui/button.tsx",
          "type": "registry:ui",
          "target": "@ui/button.tsx"
        }
      ]
    },
    {
      "name": "autocomplete-field",
      "type": "registry:ui",
      "title": "Autocomplete Field",
      "description": "Controlled autocomplete field used by Therapy search flows.",
      "registryDependencies": [
        "geraldbahati/therapy-ui/theme",
        "geraldbahati/therapy-ui/utils",
        "geraldbahati/therapy-ui/icons"
      ],
      "files": [
        {
          "path": "registry/ui/autocomplete-field.tsx",
          "type": "registry:ui",
          "target": "@ui/autocomplete-field.tsx"
        }
      ]
    },
    {
      "name": "chip-list",
      "type": "registry:ui",
      "title": "Chip List",
      "description": "Removable selected-item chips.",
      "registryDependencies": [
        "geraldbahati/therapy-ui/utils",
        "geraldbahati/therapy-ui/icons"
      ],
      "files": [
        {
          "path": "registry/ui/chip-list.tsx",
          "type": "registry:ui",
          "target": "@ui/chip-list.tsx"
        }
      ]
    },
    {
      "name": "search-field",
      "type": "registry:ui",
      "title": "Search Field",
      "description": "Dashed-underline search input with optional clear action.",
      "registryDependencies": [
        "geraldbahati/therapy-ui/theme",
        "geraldbahati/therapy-ui/utils",
        "geraldbahati/therapy-ui/icons"
      ],
      "files": [
        {
          "path": "registry/ui/search-field.tsx",
          "type": "registry:ui",
          "target": "@ui/search-field.tsx"
        }
      ]
    },
    {
      "name": "filter-controls",
      "type": "registry:ui",
      "title": "Filter Controls",
      "description": "Filter blocks, disclosures, selects, autocomplete, and selected chips.",
      "registryDependencies": [
        "geraldbahati/therapy-ui/theme",
        "geraldbahati/therapy-ui/utils",
        "geraldbahati/therapy-ui/icons",
        "geraldbahati/therapy-ui/autocomplete-field"
      ],
      "files": [
        {
          "path": "registry/ui/filter-controls.tsx",
          "type": "registry:ui",
          "target": "@ui/filter-controls.tsx"
        }
      ]
    }
  ]
}
